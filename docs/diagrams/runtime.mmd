flowchart TD
    A[Friend Telegram message] --> B[aiogram handler]
    B --> LG[LangGraph.invoke]

    subgraph Graph[LangGraph state machine]
        AC[auth_check] --> Branch{user state}
        Branch -- whitelisted --> R[retrieve_hybrid<br/>Qdrant + BM25]
        Branch -- unknown --> AR[auth_request_admin]
        Branch -- pending --> PR[reply_awaiting]
        Branch -- blocked --> SE([silent])

        R --> RR[recency_rerank]
        RR --> M[load_user_memory]
        M --> S[load_session]
        S --> BP[build_prompt<br/>cacheable prefix + dynamic suffix]
        BP --> G[openai_chat<br/>gpt-4o-mini]
        G --> GR[guardrails]
        GR --> SF{shadow?}
        SF -- yes --> SL[append shadow_log]
        SF -- no --> SD[send_reply]
        SD --> AT[append_session_log]
        AT --> CT{session timeout?}
        CT -- yes --> UM[update_user_memory<br/>async]
        CT -- no --> EE([end])
        UM --> EE
        SL --> EE
        AR --> EE
        PR --> EE
        SE --> EE
    end

    LG --> O[Send Telegram reply]
    LG -.trace.-> LSM[LangSmith]

    style G fill:#dbeafe
    style GR fill:#fee2e2
    style SL fill:#e0e7ff
    style R fill:#dcfce7
    style UM fill:#fef3c7
