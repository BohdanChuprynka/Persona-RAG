# Copy to .env and fill in. Never commit .env.

# === Persona identity (used in system prompt) ===
PERSONA_NAME=
PERSONA_LANGUAGE=en
# 1-3 sentences. Who is this persona? Speaking style, tone, common topics, quirks.
# This gets pasted into the system prompt verbatim.
PERSONA_DESCRIPTION=

# === Telegram bot ===
TELEGRAM_BOT_TOKEN=
# Your own numeric Telegram user ID. Bot treats you as admin (auth approvals, /commands).
# This is also the persona owner — the person whose messages count as "your_reply" in ingest.
ADMIN_TELEGRAM_ID=

# === OpenAI ===
OPENAI_API_KEY=
# Response generation. Defaults to gpt-4o-mini for cost. Swap to gpt-4o for higher quality.
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# === Storage (relative paths under repo root) ===
VECTOR_DB_PATH=data/vectors.lance
USER_DB_PATH=data/persona.db

# === Ingest tuning ===
# Consecutive same-sender messages within this window collapse into one.
MESSAGE_BURST_SECONDS=300
# Gap above this opens a new conversation session.
SESSION_BREAK_HOURS=6
# Sessions shorter than this are dropped (too little signal).
MIN_SESSION_TURNS=4
# Drop group chats (>2 participants). Set true only if you want their noise.
INCLUDE_GROUP_CHATS=false
# Last N messages included as incoming_context per persona turn.
CONTEXT_TURNS=10

# === PII redaction ===
# Comma-separated pattern set: phone,email,address,iban,credit_card
PII_PATTERNS=phone,email,address,iban,credit_card
# Comma-separated personal names to whole-word redact. Case-insensitive.
PII_NAMES=
# Token that replaces redacted spans.
PII_REPLACE_TOKEN=<REDACTED>
# Set true to strip URLs from messages (off by default — URLs are identity markers).
STRIP_URLS=false

# === Retrieval ===
TOP_K=8
# Newer messages get weighted higher. Half-life in days.
RECENCY_HALF_LIFE_DAYS=180

# === Generation ===
MAX_REPLY_TOKENS=300
TEMPERATURE=0.8

# === Conversation state ===
# How many last turns of current session to include in prompt as raw context.
CURRENT_SESSION_WINDOW=10
# Silence threshold after which the current session is closed and a summary
# is written to per-user memory.
SESSION_TIMEOUT_MINUTES=30

# === Rate limits ===
MAX_MESSAGES_PER_MINUTE=6
MAX_OPENAI_RPS=2
# Messages buffered per pending user while admin decides whether to approve.
PENDING_BUFFER_SIZE=10
