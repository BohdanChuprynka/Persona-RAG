# Copy to .env and fill in. Never commit .env.

# === Persona identity (used in system prompt) ===
PERSONA_NAME=
PERSONA_LANGUAGE=en
# 1-3 sentences. Who is this persona? Speaking style, tone, common topics, quirks.
# This gets pasted into the system prompt verbatim.
PERSONA_DESCRIPTION=

# === Telegram bot ===
TELEGRAM_BOT_TOKEN=
# Your own numeric Telegram user ID. Bot treats you as admin (auth approvals, /commands).
# This is also the persona owner — the person whose messages count as "your_reply" in ingest.
ADMIN_TELEGRAM_ID=

# === OpenAI ===
OPENAI_API_KEY=
# Response generation. Defaults to gpt-4o-mini for cost. Swap to gpt-4o for quality.
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# === Qdrant (vector DB) ===
# Local docker-compose default: http://localhost:6333
# Cloud: https://YOUR-CLUSTER.qdrant.io
QDRANT_URL=http://localhost:6333
# Leave empty for local docker-compose; required for Qdrant Cloud.
QDRANT_API_KEY=
QDRANT_COLLECTION=persona_turns

# === LangSmith tracing ===
# Free tier: https://smith.langchain.com — observability for every LangGraph run.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=persona-rag

# === MLflow eval tracking ===
# Local default: file-backed at ./mlruns
# Docker-compose default: http://localhost:5001 (host port 5000 reserved by macOS AirPlay)
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT=persona-rag-eval

# === Storage (relative paths under repo root) ===
USER_DB_PATH=data/persona.db
SHADOW_LOG_PATH=data/shadow_log.jsonl

# === Ingest tuning ===
# Consecutive same-sender messages within this window collapse into one.
MESSAGE_BURST_SECONDS=300
# Gap above this opens a new conversation session.
SESSION_BREAK_HOURS=6
# Sessions shorter than this are dropped (too little signal).
MIN_SESSION_TURNS=4
# Drop group chats (>2 participants). Set true only if you want their noise.
INCLUDE_GROUP_CHATS=false
# Last N messages included as incoming_context per persona turn.
CONTEXT_TURNS=10

# === PII redaction ===
PII_PATTERNS=phone,email,address,iban,credit_card
PII_NAMES=
PII_REPLACE_TOKEN=<REDACTED>
STRIP_URLS=false

# === Retrieval ===
TOP_K=8
# Newer messages get weighted higher. Half-life in days.
RECENCY_HALF_LIFE_DAYS=180
# Hybrid retrieval fusion weight. 1.0 = dense only, 0.0 = BM25 only.
HYBRID_DENSE_ALPHA=0.7

# === Generation ===
MAX_REPLY_TOKENS=300
TEMPERATURE=0.8
# Enable OpenAI automatic prompt caching (system+few-shot prefix). Saves ~50% input cost.
ENABLE_PROMPT_CACHING=true

# === Conversation state ===
CURRENT_SESSION_WINDOW=10
SESSION_TIMEOUT_MINUTES=30

# === Shadow mode (no replies; logs only) ===
# When true, bot generates replies internally but does NOT send them to Telegram.
# Each (incoming, generated, your_actual_reply) triple is logged to SHADOW_LOG_PATH
# for later DPO dataset construction and persona-match evaluation.
SHADOW_MODE=false

# === Rate limits ===
MAX_MESSAGES_PER_MINUTE=6
MAX_OPENAI_RPS=2
PENDING_BUFFER_SIZE=10

# === Insights pipeline (Stage G design — see docs/superpowers/specs/) ===
INSIGHTS_ENABLED=true
INSIGHTS_EXTRACT_MODEL=gpt-4o
INSIGHTS_CONSOLIDATE_MODEL=gpt-4o-mini
# Only extract from chat sessions starting within last N years. 2.5 default
# drops "kid-Bohdan" noise while keeping enough trajectory for adults.
INSIGHTS_HISTORY_YEARS=2.5
INSIGHTS_MIN_SESSION_TURNS=10
INSIGHTS_MIN_SESSION_CHARS=300
INSIGHTS_MAX_SESSIONS=600
# Runtime retrieval
INSIGHTS_TOP_K_SEMANTIC=3
INSIGHTS_TOP_N_STATIC=5
INSIGHTS_RECENCY_HALF_LIFE_DAYS=365
# Routing thresholds
INSIGHTS_CONFIDENCE_THRESHOLD=0.7
INSIGHTS_MIN_EVIDENCE=2
INSIGHTS_STALE_DEMOTE_YEARS=2.0
INSIGHTS_STALE_DEMOTE_MIN_EVIDENCE=5
INSIGHTS_BUDGET_HARD_CAP_USD=5.0
# Optional overrides for bundled YAML files
# INSIGHTS_SYNONYMS_PATH=
# INSIGHTS_ONBOARDING_PATH=
INSIGHTS_STATIC_PATTERNS_ENABLED=true
INSIGHTS_PROMPT_TOP_ENTITIES=3
# When true, persona description in prompt is generated from user_verified +
# onboarding insights; falls back to PERSONA_DESCRIPTION env var when empty.
INSIGHTS_USE_GENERATED_PERSONA_DESCRIPTION=true
QDRANT_INSIGHTS_COLLECTION=self_insights
